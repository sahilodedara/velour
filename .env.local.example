# --- Supabase (enables real admin auth + live database) ---------------------
# Copy this file to ".env.local" and paste your project's values.
# Find them in Supabase: Project Settings → API.
#   • Project URL  → NEXT_PUBLIC_SUPABASE_URL
#   • anon / public (publishable) key → NEXT_PUBLIC_SUPABASE_ANON_KEY
# These are safe to expose in the browser (protected by Row Level Security).
# Leave blank/unset to keep the demo admin gate (admin / velour2026).

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
